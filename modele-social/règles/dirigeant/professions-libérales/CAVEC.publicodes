        - montant: 288 €/an
          plafond:
            variations:
              - si: date < 01/2026
                alors: 16190 €/an
              - sinon: 14919 €/an
        - montant: 396 €/an
          plafond:
            variations:
              - si: date < 01/2026
                alors: 44790 €/an
              - sinon: 44822 €/an
        - montant: 612 €/an
          plafond:
            variations:
              - si: date < 01/2026
                alors: 79040 €/an
